# Flask Security Configuration
# Copy this file to .env and set your own values

# REQUIRED: Global access PIN (grants view/edit access to games and rosters)
# Must be at least 6 characters
# DO NOT use default values like '1717'
FLOORBALL_PIN=your_secure_pin_here

# OPTIONAL: Separate admin PIN (grants access to the admin panel)
# Must differ from FLOORBALL_PIN and be at least 6 characters
# If not set, admin panel is only accessible via user accounts with is_admin=True
ADMIN_PIN=your_admin_pin_here

# REQUIRED: Flask secret key for session security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# DO NOT use 'dev_secret' in production
FLASK_SECRET_KEY=your_secret_key_here

# OPTIONAL: Session cookie security (defaults to True for production)
# Set to False only for local development without HTTPS
SESSION_COOKIE_SECURE=True

# OPTIONAL: Default language (en or de)
# Default: en
DEFAULT_LANG=en
